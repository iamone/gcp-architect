export ZONE=europe-west4-a
export REGION=europe-west4
export PROJECTID=qwiklabs-gcp-00-8e4d7b53c8d4


gcloud config set compute/zone $ZONE


#------ Custom role


export CUSTOM_ROLE_NAME=orca_storage_editor_140

cat > role-definition.yaml <<EOF
title: "orca_storage_editor"
description: "Provides the Google Cloud storage bucket and object permissions required to be able to create and update storage objects"
stage: "GA"
includedPermissions:
- storage.buckets.get
- storage.objects.get
- storage.objects.list
- storage.objects.update
- storage.objects.create
EOF

gcloud iam roles create $CUSTOM_ROLE_NAME --project $PROJECTID --file role-definition.yaml

gcloud iam roles list --project $PROJECTID


#------ Service account

export SA_NAME=orca-private-cluster-802-sa

gcloud iam service-accounts create $SA_NAME \
  --description="Service account for the private cluster." \
  --display-name="$SA_NAME"

#------ SA role assignments

gcloud projects add-iam-policy-binding $PROJECTID \
    --member serviceAccount:$SA_NAME@$PROJECTID.iam.gserviceaccount.com \
    --role projects/$PROJECTID/roles/$CUSTOM_ROLE_NAME

gcloud projects add-iam-policy-binding $PROJECTID \
    --member serviceAccount:$SA_NAME@$PROJECTID.iam.gserviceaccount.com \
    --role roles/monitoring.viewer

gcloud projects add-iam-policy-binding $PROJECTID \
    --member serviceAccount:$SA_NAME@$PROJECTID.iam.gserviceaccount.com \
    --role roles/monitoring.metricWriter

gcloud projects add-iam-policy-binding $PROJECTID \
    --member serviceAccount:$SA_NAME@$PROJECTID.iam.gserviceaccount.com \
    --role roles/logging.logWriter

